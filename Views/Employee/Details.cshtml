@model YogaStudioLRAManagementSystem.Models.Employee
@{
    ViewData["Title"] = "Employee Details";
}

<h2>Employee Details</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Employee ID</dt>
            <dd class="col-sm-8">@Model.EmployeeId</dd>

            <dt class="col-sm-4">First Name</dt>
            <dd class="col-sm-8">@Model.FirstName</dd>

            <dt class="col-sm-4">Last Name</dt>
            <dd class="col-sm-8">@Model.LastName</dd>

            <dt class="col-sm-4">Studio Role</dt>
            <dd class="col-sm-8">@Model.StudioRole?.RoleName</dd>

            <dt class="col-sm-4">Certification</dt>
            <dd class="col-sm-8">@(Model.Certification ?? "N/A")</dd>

            <dt class="col-sm-4">Hire Date</dt>
            <dd class="col-sm-8">@Model.HireDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-4">Vacation Balance</dt>
            <dd class="col-sm-8">@Model.VacationBalance days</dd>

            <dt class="col-sm-4">Sick Leave Balance</dt>
            <dd class="col-sm-8">@Model.SickLeaveBalance days</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.EmployeeId"
           class="btn btn-warning">Edit</a>
    }
</div>