@model YogaStudioLRAManagementSystem.Models.Employee
@{
    ViewData["Title"] = "Delete Employee";
}

<h2>Delete Employee</h2>

@* Shows error if employee has a linked User account *@
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="alert alert-warning">
    Are you sure you want to delete this employee? This action cannot be undone.
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.FirstName @Model.LastName</dd>

            <dt class="col-sm-4">Studio Role</dt>
            <dd class="col-sm-8">@Model.StudioRole?.RoleName</dd>

            <dt class="col-sm-4">Certification</dt>
            <dd class="col-sm-8">@(Model.Certification ?? "N/A")</dd>

            <dt class="col-sm-4">Hire Date</dt>
            <dd class="col-sm-8">@Model.HireDate.ToString("yyyy-MM-dd")</dd>
        </dl>
    </div>
</div>

@* Confirmation form — posts to DeleteConfirmed action *@
<form asp-action="Delete" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="EmployeeId" />

    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>