@model YogaStudioLRAManagementSystem.ViewModels.UserViewModel

@{
    ViewData["Title"] = "Reset Password";
}

<h2>Reset Password</h2>

<div class="alert alert-warning">
    Are you sure you want to reset the password for this user? They will be required to change it on next login.
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Username</dt>
            <dd class="col-sm-8">@Model.UserName</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.EmailAddress</dd>

            <dt class="col-sm-4">Role</dt>
            <dd class="col-sm-8">@Model.Role</dd>

            <dt class="col-sm-4">Employee</dt>
            <dd class="col-sm-8">@Model.EmployeeName</dd>
        </dl>
    </div>
</div>

@* confirmation form to reset password *@
<form asp-action="ResetPasswordConfirmed" asp-controller="User" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input type="hidden" name="userId" value="@Model.UserId" />

    <button type="submit" class="btn btn-warning">Yes, Reset Password</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>