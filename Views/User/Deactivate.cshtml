@model YogaStudioLRAManagementSystem.ViewModels.UserViewModel

@{
    ViewData["Title"] = "Deactivate User";
}

<h2>Deactivate User</h2>

<div class="alert alert-warning">
    Are you sure you want to deactivate this user? They will no longer be able to log in.
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Username</dt>
            <dd class="col-sm-8">@Model.UserName</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.EmailAddress</dd>

            <dt class="col-sm-4">Role</dt>
            <dd class="col-sm-8">@Model.Role</dd>

            <dt class="col-sm-4">Employee</dt>
            <dd class="col-sm-8">@Model.EmployeeName</dd>
        </dl>
    </div>
</div>

@* confirmation form to deactivate user *@
<form asp-action="DeactivateConfirmed" asp-controller="User" method="post" class="mt-3">
    @Html.AntiForgeryToken()
    <input type="hidden" name="userId" value="@Model.UserId" />

    <button type="submit" class="btn btn-danger">Yes, Deactivate</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>