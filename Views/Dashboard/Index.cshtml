@model YogaStudioLRAManagementSystem.ViewModels.DashboardViewModel
@using YogaStudioLRAManagementSystem.Constants

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4">Welcome, @User.Identity?.Name</h2>

    @* STAFF DASHBOARD  *@
    @if (User.IsInRole(UserRoles.STAFF))
    {
        <div class="row mb-4">
            @* summary cards - vacation balance, sick leave balance and hourse logged this month *@
            <div class="col-md-4">
                <div class="card text-white bg-primary">
                    <div class="card-body">
                        <h6 class="card-title">Vacation Balance</h6>
                        <h3 class="mb-0">@Model.VacationBalance days</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-info">
                    <div class="card-body">
                        <h6 class="card-title">Sick Leave Balance</h6>
                        <h3 class="mb-0">@Model.SickLeaveBalance days</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-success">
                    <div class="card-body">
                        <h6 class="card-title">Hours This Month</h6>
                        <h3 class="mb-0">@Model.HoursThisMonth.ToString("F2")</h3>
                    </div>
                </div>
            </div>
        </div>

        @* Quick action buttons - clock in/out and submit leave request*@
        <div class="mb-4">
            <a asp-controller="Attendance" asp-action="ClockIn" class="btn btn-primary">Clock In / Out</a>
            <a asp-controller="LeaveRequest" asp-action="Create" class="btn btn-outline-primary">Submit Leave Request</a>
        </div>

        @* Upcoming approved leave request table*@
        <div class="card mb-4 shadow-sm">
            <div class="card-header"><strong>Upcoming Approved Leave</strong></div>
            <div class="card-body">
                @if (!Model.UpcomingApprovedLeave.Any())
                {
                    <p class="text-muted mb-0">No upcoming approved leave.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lr in Model.UpcomingApprovedLeave)
                            {
                                <tr>
                                    <td>@lr.LeaveType?.Name</td>
                                    <td>@lr.StartDate.ToString("yyyy-MM-dd")</td>
                                    <td>@lr.EndDate.ToString("yyyy-MM-dd")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        @* Pending leave requests table*@
        <div class="card shadow-sm">
            <div class="card-header"><strong>My Pending Requests</strong></div>
            <div class="card-body">
                @if (!Model.MyPendingRequests.Any())
                {
                    <p class="text-muted mb-0">No pending requests.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lr in Model.MyPendingRequests)
                            {
                                <tr>
                                    <td>@lr.LeaveType?.Name</td>
                                    <td>@lr.StartDate.ToString("yyyy-MM-dd")</td>
                                    <td>@lr.EndDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <a asp-controller="LeaveRequest" asp-action="Edit" asp-route-id="@lr.RequestId" class="btn btn-sm btn-warning">Edit</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }

    @* MANAGER DASHBOARD   *@
    else if (User.IsInRole(UserRoles.MANAGER))
    {
        @* Summary cards - Pending request count, currently on leave count, today's attendance record count' *@
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card text-white bg-warning">
                    <div class="card-body">
                        <h6 class="card-title">Pending Requests</h6>
                        <h3 class="mb-0">@Model.TeamPendingRequests.Count()</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-info">
                    <div class="card-body">
                        <h6 class="card-title">Currently on Leave</h6>
                        <h3 class="mb-0">@Model.TeamApprovedLeave.Count()</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-secondary">
                    <div class="card-body">
                        <h6 class="card-title">Today's Attendance Records</h6>
                        <h3 class="mb-0">@Model.TodayAttendance.Count()</h3>
                    </div>
                </div>
            </div>
        </div>

        @* Today's attendance progress bar using bootstrap*@
        <div class="card mb-4 shadow-sm">
            <div class="card-header"><strong>Today's Attendance Summary</strong></div>
            <div class="card-body">
                @{
                    var managerTotalToday = Model.TodayPresent + Model.TodayAbsent + Model.TodayOnLeave;
                }
                @if (managerTotalToday == 0)
                {
                    <p class="text-muted mb-0">No attendance records yet for today.</p>
                }
                else
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-success"><strong>Present</strong></span>
                            <span>@Model.TodayPresent of @managerTotalToday</span>
                        </div>
                        <div class="progress" style="height: 22px;">
                            <div class="progress-bar bg-success"
                                 role="progressbar"
                                 style="width: @((Model.TodayPresent * 100.0) / managerTotalToday)%">
                                @Model.TodayPresent
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-danger"><strong>Absent</strong></span>
                            <span>@Model.TodayAbsent of @managerTotalToday</span>
                        </div>
                        <div class="progress" style="height: 22px;">
                            <div class="progress-bar bg-danger"
                                 role="progressbar"
                                 style="width: @((Model.TodayAbsent * 100.0) / managerTotalToday)%">
                                @Model.TodayAbsent
                            </div>
                        </div>
                    </div>
                    <div class="mb-0">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-info"><strong>On Leave</strong></span>
                            <span>@Model.TodayOnLeave of @managerTotalToday</span>
                        </div>
                        <div class="progress" style="height: 22px;">
                            <div class="progress-bar bg-info"
                                 role="progressbar"
                                 style="width: @((Model.TodayOnLeave * 100.0) / managerTotalToday)%">
                                @Model.TodayOnLeave
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* Team pending requests table, awaiting manager action *@
        <div class="card mb-4 shadow-sm">
            <div class="card-header">
                <strong>Pending Leave Requests</strong>
                <a asp-controller="LeaveRequest" asp-action="Index" class="btn btn-sm btn-outline-primary float-end">View All</a>
            </div>
            <div class="card-body">
                @if (!Model.TeamPendingRequests.Any())
                {
                    <p class="text-muted mb-0">No pending requests awaiting action.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Employee</th>
                                <th>Type</th>
                                <th>Start</th>
                                <th>End</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lr in Model.TeamPendingRequests)
                            {
                                <tr>
                                    <td>@lr.Employee?.FirstName @lr.Employee?.LastName</td>
                                    <td>@lr.LeaveType?.Name</td>
                                    <td>@lr.StartDate.ToString("yyyy-MM-dd")</td>
                                    <td>@lr.EndDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <a asp-controller="LeaveRequest" asp-action="Review" asp-route-id="@lr.RequestId" class="btn btn-sm btn-primary">Review</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        @* Team currently on leave table *@
        <div class="card mb-4 shadow-sm">
            <div class="card-header"><strong>Currently on Leave</strong></div>
            <div class="card-body">
                @if (!Model.TeamApprovedLeave.Any())
                {
                    <p class="text-muted mb-0">No one is currently on leave.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Employee</th>
                                <th>Type</th>
                                <th>Until</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lr in Model.TeamApprovedLeave)
                            {
                                <tr>
                                    <td>@lr.Employee?.FirstName @lr.Employee?.LastName</td>
                                    <td>@lr.LeaveType?.Name</td>
                                    <td>@lr.EndDate.ToString("yyyy-MM-dd")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

        @* Today's attendance table *@
        <div class="card shadow-sm">
            <div class="card-header">
                <strong>Today's Attendance</strong>
                <a asp-controller="Attendance" asp-action="Index" class="btn btn-sm btn-outline-primary float-end">Full Report</a>
            </div>
            <div class="card-body">
                @if (!Model.TodayAttendance.Any())
                {
                    <p class="text-muted mb-0">No attendance records for today yet. Visit the Attendance Report to generate them.</p>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Employee</th>
                                <th>Status</th>
                                <th>Clock In</th>
                                <th>Clock Out</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in Model.TodayAttendance)
                            {
                                <tr>
                                    <td>@a.Employee?.FirstName @a.Employee?.LastName</td>
                                    <td>@a.Status</td>
                                    <td>@(a.ClockIn?.ToString("HH:mm") ?? "-")</td>
                                    <td>@(a.ClockOut?.ToString("HH:mm") ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }

    @*  ADMIN DASHBOARD  *@
    else if (User.IsInRole(UserRoles.ADMIN))
    {
        @* Summary cards - Total empliyees, Active users, pending requests, today;s records *@
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card text-white bg-primary">
                    <div class="card-body">
                        <h6 class="card-title">Total Employees</h6>
                        <h3 class="mb-0">@Model.TotalEmployees</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-info">
                    <div class="card-body">
                        <h6 class="card-title">Active Users</h6>
                        <h3 class="mb-0">@Model.TotalActiveUsers</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-warning">
                    <div class="card-body">
                        <h6 class="card-title">Pending Requests</h6>
                        <h3 class="mb-0">@Model.TotalPendingRequests</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-dark bg-light">
                    <div class="card-body">
                        <h6 class="card-title">Today's Total Records</h6>
                        <h3 class="mb-0">@(Model.TodayPresent + Model.TodayAbsent + Model.TodayOnLeave)</h3>
                    </div>
                </div>
            </div>
        </div>

        @* Most popular Leave types taken this month - progress bar using bootstrap *@
        <div class="card mb-4 shadow-sm">
            <div class="card-header"><strong>Leave Types Taken This Month</strong></div>
            <div class="card-body">
                @if (!Model.LeaveTypeCounts.Any())
                {
                    <p class="text-muted mb-0">No approved leave requests this month.</p>
                }
                else
                {
                    //find the largest count so bars scale relative to the biggest one
                    var maxCount = Model.LeaveTypeCounts.Values.Max();
                    //to protect against divide-by-zero when everything is 0
                    if (maxCount == 0) { maxCount = 1; }

                    foreach (var entry in Model.LeaveTypeCounts.OrderByDescending(e => e.Value))
                    {
                        var widthPercent = (entry.Value * 100.0) / maxCount;

                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span><strong>@entry.Key</strong></span>
                                <span>@entry.Value request@(entry.Value == 1 ? "" : "s")</span>
                            </div>
                            <div class="progress" style="height: 22px;">
                                @if (entry.Value > 0)
                                {
                                    <div class="progress-bar bg-primary"
                                         role="progressbar"
                                         style="width: @widthPercent%">
                                        @entry.Value
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        @* Today's attendance breakdown *@
        <div class="card mb-4 shadow-sm">
            <div class="card-header"><strong>Today's Attendance Summary</strong></div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-md-4">
                        <h6 class="text-success">Present</h6>
                        <h2 class="text-success">@Model.TodayPresent</h2>
                    </div>
                    <div class="col-md-4">
                        <h6 class="text-danger">Absent</h6>
                        <h2 class="text-danger">@Model.TodayAbsent</h2>
                    </div>
                    <div class="col-md-4">
                        <h6 class="text-info">On Leave</h6>
                        <h2 class="text-info">@Model.TodayOnLeave</h2>
                    </div>
                </div>
            </div>
        </div>

        @* Admin quick links - Manage employees, users, leave requests and attendance report*@
        <div class="card shadow-sm">
            <div class="card-header"><strong>Quick Actions</strong></div>
            <div class="card-body d-flex justify-content-center flex-wrap gap-2">
                <a asp-controller="Employee" asp-action="Index" class="btn btn-outline-primary me-2">Manage Employees</a>
                <a asp-controller="User" asp-action="Index" class="btn btn-outline-primary me-2">Manage Users</a>
                <a asp-controller="LeaveRequest" asp-action="Index" class="btn btn-outline-primary me-2">Review Leave Requests</a>
                <a asp-controller="Attendance" asp-action="Index" class="btn btn-outline-primary">Attendance Report</a>
            </div>
        </div>
    }
</div>