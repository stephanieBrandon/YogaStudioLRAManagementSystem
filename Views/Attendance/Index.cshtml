@using YogaStudioLRAManagementSystem.Helpers
@model YogaStudioLRAManagementSystem.ViewModels.AttendanceViewModel
@using YogaStudioLRAManagementSystem.Constants

@{
    ViewData["Title"] = "Attendance";
    var isStaff = User.IsInRole(UserRoles.STAFF);
}

<div class="container mt-4">
    <h2>@(isStaff ? "My Attendance History" : "Attendance Report")</h2>

    @if (isStaff)
    {
        <p class="text-muted">Viewing records for @(new DateTime(2000, Model.SelectedMonth, 1).ToString("MMMM")) @Model.SelectedYear</p>
    }
    else
    {
        <p class="text-muted">Viewing records from @Model.StartDate.ToString("yyyy-MM-dd") to @Model.EndDate.ToString("yyyy-MM-dd")</p>
    }

    @* STAFF FILTERS *@
    @if (isStaff)
    {
        <form method="get" asp-action="Index" class="row g-3 mb-4">
            <div class="col-md-3">
                <label class="form-label">Month</label>
                <select name="month" class="form-select" asp-items="Model.MonthOptions"></select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Year</label>
                <select name="year" class="form-select" asp-items="Model.YearOptions"></select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
            </div>
        </form>
    }

    @* MANAGER/ADMIN FILTERS *@
    else
    {
        <form method="get" asp-action="Index" class="row g-3 mb-4">
            <div class="col-md-3">
                <label class="form-label">Employee</label>
                <select name="employeeId" class="form-select" asp-items="Model.EmployeeOptions">
                    <option value="">All Staff</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Start Date</label>
                <input type="date" name="startDate" class="form-control"
                       value="@Model.StartDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2">
                <label class="form-label">End Date</label>
                <input type="date" name="endDate" class="form-control"
                       value="@Model.EndDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select name="status" class="form-select" asp-items="Model.StatusOptions">
                    <option value="">All Statuses</option>
                </select>
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
            </div>
        </form>
    }

    @* SUMMARY CARDS *@
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">Total Hours</h6>
                    <h3>@Model.TotalHours.ToString("F2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">Total Records</h6>
                    <h3>@Model.Records.Count()</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">Days Present</h6>
                    <h3>@Model.Records.Count(r => r.Status == AttendanceStatus.PRESENT)</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">Days Absent</h6>
                    <h3>@Model.Records.Count(r => r.Status == AttendanceStatus.ABSENT)</h3>
                </div>
            </div>
        </div>
    </div>

    @* RECORDS TABLE *@
    @if (!Model.Records.Any())
    {
        <div class="alert alert-info">No attendance records found for the selected filters.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        @if (!isStaff)
                        {
                            <th>Employee</th>
                        }
                        <th>Date</th>
                        <th>Clock In</th>
                        <th>Clock Out</th>
                        <th>Total Hours</th>
                        <th>Status</th>
                        @if (!isStaff)
                        {
                            <th></th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in Model.Records)
                    {
                        <tr>
                            @if (!isStaff)
                            {
                                <td>@record.Employee.FirstName @record.Employee.LastName</td>
                            }
                            <td>@record.Date.ToString("yyyy-MM-dd")</td>
                            <td>@(record.ClockIn?.ToEastern().ToString("hh:mm tt") ?? "--")</td>
                            <td>@(record.ClockOut?.ToEastern().ToString("hh:mm tt") ?? "--")</td>
                            <td>@(record.TotalHours?.ToString("F2") ?? "--")</td>
                            <td>
                                @{
                                    var badgeClass = record.Status switch
                                    {
                                        var s when s == AttendanceStatus.PRESENT => "badge bg-success",
                                        var s when s == AttendanceStatus.ABSENT => "badge bg-danger",
                                        var s when s == AttendanceStatus.ON_LEAVE => "badge bg-info",
                                        _ => "badge bg-secondary"
                                    };
                                }
                                <span class="@badgeClass">@record.Status</span>
                            </td>
                            @* Edit button - Manager and Admin only *@
                            @if (!isStaff)
                            {
                                <td>
                                    <a asp-action="Edit" asp-route-id="@record.AttendanceId"
                                       class="btn btn-sm btn-warning">Edit</a>
                                </td>
                            }
                            else
                            {
                                <td></td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (isStaff)
    {
        <div class="mt-3">
            <a asp-action="ClockIn" class="btn btn-outline-success">Go to Clock In</a>
        </div>
    }
</div>