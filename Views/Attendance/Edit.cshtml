@using YogaStudioLRAManagementSystem.Helpers
@model YogaStudioLRAManagementSystem.Models.Attendance

@{
    ViewData["Title"] = "Edit Attendance";
}

<h2>Edit Attendance</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" asp-controller="Attendance" method="post">
            @Html.AntiForgeryToken()

            @* hidden field so controller receives the AttendanceId *@
            <input type="hidden" name="attendanceId" value="@Model.AttendanceId" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            @* read only info - not editable *@
            <div class="mb-3">
                <label class="form-label">Employee</label>
                <input class="form-control" value="@Model.Employee.FirstName @Model.Employee.LastName" disabled />
            </div>

            <div class="mb-3">
                <label class="form-label">Date</label>
                <input class="form-control" value="@Model.Date.ToString("yyyy-MM-dd")" disabled />
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Clock In</label>
                    <input type="time" name="clockIn" class="form-control"
                           value="@(Model.ClockIn?.ToEastern().ToString("HH:mm"))"
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Clock Out</label>
                    <input type="time" name="clockOut" class="form-control"
                           value="@(Model.ClockOut?.ToEastern().ToString("HH:mm"))"
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Current Total Hours</label>
                <input class="form-control" value="@(Model.TotalHours?.ToString("F2") ?? "--")" disabled />
                <small class="text-muted">Total hours will be recalculated automatically on save.</small>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>