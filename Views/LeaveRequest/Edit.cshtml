@using System.Security.Claims
@model YogaStudioLRAManagementSystem.Models.LeaveRequest

@{
    ViewData["Title"] = "Edit";

    var employeeId = User.FindFirstValue("EmployeeId");
}

<h2>Edit Leave Request</h2>

<hr />

<div class="row">
    <div class="col-md-4">

        <form asp-action="Edit">

            <input type="hidden" asp-for="RequestId" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="StartDate" class="control-label"></label>
                <input asp-for="StartDate" class="form-control" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="EndDate" class="control-label"></label>
                <input asp-for="EndDate" class="form-control" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <!-- STATUS should NOT be editable -->
            <div class="form-group">
                <label>Status</label>
                <input asp-for="Status" class="form-control" readonly />
            </div>

            <div class="form-group">
                <label asp-for="Reason" class="control-label"></label>
                <input asp-for="Reason" class="form-control" />
                <span asp-validation-for="Reason" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="LeaveTypeId" class="form-label"></label>
                <select asp-for="LeaveTypeId"
                        class="form-select"
                        asp-items="ViewBag.LeaveTypeId">
                </select>
                <span asp-validation-for="LeaveTypeId" class="text-danger"></span>
            </div>
            <input type="hidden" asp-for="EmployeeId" value="@employeeId"/>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    Save changes
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}