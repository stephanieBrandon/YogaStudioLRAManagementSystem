@model YogaStudioLRAManagementSystem.Models.LeaveRequest

@{
    ViewData["Title"] = "Delete";
}

<h2>Delete Leave Request</h2>
<hr />
<p class="alert-info"><b>Are you sure you want to delete this leave request?</b></p>
<div>
    <hr />
    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row">
                @if (User.IsInRole("Admin"))
                {
                    <dt class="col-sm-4">Employee</dt>
                    <dd class="col-sm-8">
                        @Model.Employee.FirstName, @Model.Employee.LastName
                    </dd>
                }
                <dt class = "col-sm-4">Start Date</dt>
                <dd class = "col-sm-8">@Model.StartDate</dd>

                <dt class = "col-sm-4">EndDate</dt>
                <dd class = "col-sm-8">@Model.EndDate</dd>

                <dt class = "col-sm-4">Status</dt>
                <dd class = "col-sm-8">@Model.Status</dd>

                <dt class = "col-sm-4">Reason</dt>
                <dd class = "col-sm-8">@Model.Reason</dd>

                <dt class = "col-sm-4">LeaveType</dt>
                <dd class = "col-sm-8">@Model.LeaveType.Name</dd>
            </dl>
        </div>
    </div>
    <form asp-action="Delete" class="mt-3">
        <input type="hidden" asp-for="RequestId" />
        <input type="submit" value="Delete" class="btn btn-outline-danger" /> 
        <a asp-action="Index" class="btn sm btn-outline-warning">Cancel</a>
    </form>
</div>
