@model YogaStudioLRAManagementSystem.ViewModels.LeaveRequestViewModel
@using YogaStudioLRAManagementSystem.Constants

<h1>Leave Requests</h1>

<a asp-action="Create" class="btn btn-primary">Submit New Request</a>

<hr />

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}


<h2>My Requests</h2>

<table class="table">
    <thead>
        <tr>
            <th>Start</th>
            <th>End</th>
            <th>Status</th>
            <th>Reason</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.MyRequests)
        {
            <tr>
                <td>@item.StartDate.ToShortDateString()</td>
                <td>@item.EndDate.ToShortDateString()</td>
                <td>@item.Status</td>
                <td>@item.Reason</td>
            </tr>
        }
    </tbody>
</table>

<hr />

@if (Model.Role == UserRoles.MANAGER)
{
    <h2>Team Requests</h2>

    <table class="table">
        <thead>
            <tr>
                <th>Employee</th>
                <th>Start</th>
                <th>End</th>
                <th>Status</th>
                <th>Reason</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.TeamRequests)
            {
                <tr>
                    <td>@item.Employee.FirstName</td>
                    <td>@item.StartDate.ToShortDateString()</td>
                    <td>@item.EndDate.ToShortDateString()</td>
                    <td>@item.Status</td>
                    <td>@item.Reason</td>
                </tr>
            }
        </tbody>
    </table>
}

@if (Model.Role == UserRoles.ADMIN)
{
    <h2>Admin - All Requests</h2>

    <form method="get" class="mb-3">
        <label>Status</label>
        <select name="statusFilter" class="form-control">
            <option value="">All</option>
            <option value="@LeaveRequestStatus.PENDING">Pending</option>
            <option value="@LeaveRequestStatus.APPROVED">Approved</option>
            <option value="@LeaveRequestStatus.DENIED">Denied</option>
        </select>

        <label>Employee ID</label>
        <input type="number" name="employeeIdFilter" class="form-control" />

        <button type="submit" class="btn btn-primary mt-2">Filter</button>
    </form>

    <table class="table">
        <thead>
            <tr>
                <th>Employee</th>
                <th>Start</th>
                <th>End</th>
                <th>Status</th>
                <th>Reason</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.AllRequests)
            {
                <tr>
                    <td>@item.Employee.FirstName</td>
                    <td>@item.StartDate.ToShortDateString()</td>
                    <td>@item.EndDate.ToShortDateString()</td>
                    <td>@item.Status</td>
                    <td>@item.Reason</td>
                </tr>
            }
        </tbody>
    </table>
}